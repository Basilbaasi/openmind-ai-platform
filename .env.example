# ── Environment ──────────────────────────────────────────────────
# Copy this file to .env and fill in real values.
# The application reads these via pydantic-settings.

# Application
APP_NAME=OpenMind AI Platform
APP_VERSION=0.1.0
ENVIRONMENT=development
DEBUG=true

# Server
HOST=0.0.0.0
PORT=8000
WORKERS=1

# API
API_V1_PREFIX=/api/v1

# Logging
LOG_LEVEL=DEBUG
LOG_FORMAT=text

# CORS (comma-separated origins, or * for all)
CORS_ORIGINS=["*"]

# ── Future Phases ────────────────────────────────────────────────
# DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/openmind
# REDIS_URL=redis://localhost:6379/0
# OPENAI_API_KEY=sk-...
# ANTHROPIC_API_KEY=sk-ant-...